# ──────────────────────────────────────────────────────
# Frontend Environment Variables (Vite)
# Copy this file to .env and fill in your values.
# All variables MUST be prefixed with VITE_ to be
# accessible via import.meta.env in the browser.
# ──────────────────────────────────────────────────────

# API base path used by frontend fetch calls
VITE_API_BASE_URL=/api

# Backend server URL (used by Vite dev server proxy)
VITE_BACKEND_URL=http://localhost:3001

# Vite dev server port
VITE_PORT=5173

# App display name
VITE_APP_NAME=Campus Threads Co.
